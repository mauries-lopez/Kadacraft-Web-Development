<!DOCTYPE html>

<html>
    <head>
        <title> KadaCraft </title> 
        <link rel="stylesheet" href="../css/Profile.css">
        <link rel="stylesheet" href="../css/HomeStyle.css"> 
        <link rel="stylesheet" href="../css/Character.css"> 
        <link rel="stylesheet" href="../css/ResolutionCompatible.css" defer> 
        <link type="text/css" rel="stylesheet" href="../css/Font.css">
        <link rel="icon" type="image/png" href="../image/kadacraft_weblogo.png">
        <script src="https://ajax.googleapis.com/ajax/libs/jquery/3.5.1/jquery.min.js"></script>
        <script src="../js/Home.js"></script>
        <script src="../js/Profile.js" defer></script>
        <!--<script src="../js/YouTubeApi.js"></script>-->
    </head>

    <body>

        <script>

            $(document).ready(function() {

                var channelName = "{{channelName}}";
                checkStats(channelName);

                $("#member-render").on("click", function() {
                    console.log("Easter Egg! The website was made by Atmospheric and Lloyd.");
                })

                var count = 1;
                var urlLink = "url('../image/members/builds/{{channelName}}/"+count+".png')"

                $("#builds-img").css("background-image", urlLink);

                $('#previous-img').click(function(){
                    if ( count == 1 ){
                        count = 4;
                    } else{
                        count--;
                    }
                    $("#builds-img").css("background-image", "url('../image/members/builds/{{channelName}}/"+count+".png')");
                })

                $('#next-img').click(function(){
                    if ( count > 3 ){
                        count = 1;
                    } else{
                        count++;
                    }
                    $("#builds-img").css("background-image", "url('../image/members/builds/{{channelName}}/"+count+".png')");
                })

            })
            

        </script>

        <div class="banner" id="top" style="background: linear-gradient(rgba(0, 0, 0, 0), rgba(0, 0, 0, 0)), url('../image/members/backgrounds/{{channelName}}.png'); width: 100%; height: 100vh; object-fit: fill; "> 
            <div class="navbar">
                <a class="facebook-btn" style="position:relative; left: 5em; cursor: pointer;" title="Facebook Group"><img src="../image/facebook_logo.png" class="facebook-img" id="facebook-links"></a>
                <div id="tooltip" style="position: relative; display: flex;">
                    <div id="tooltip-text" style="display: none; transform: translate(-42em, 5em);"> 
                        <a href="https://www.facebook.com/groups/KadaCraft" id="button-1" target="_blank"> <button> </button> </a>
                        <a href="https://www.facebook.com/KadaCraftSMP" id="button-2" target="_blank">  <button> </button> </a>
                    </div>
                    <a href="/"> <img src="../image/kadacraft_logo.png" style="position: relative; height: 3em; width: 100%; left: 4.05em; cursor: pointer;"> </a>
                </div>        
                <ul>
                    <li style="right: 70px;" ><a href="/" style="color: black; font-family: Minecraft; letter-spacing: 0.05em;" > Home </a></li>
                    <li style="right: 70px;"><a href="/world" style="color: black; font-family: Minecraft; letter-spacing: 0.05em;"> Worlds </a></li>       
                </ul>
            </div>

            <div id="contents-container">
    
                <div id="ytVideo-container" style="left: 0; top: 0; transform: translate(0%,0%); width: 45%; text-align: left; margin-left: 3%;">

                </div>


                <img id="member-render" src="../image/members/{{channelName}}.png" style="">

                <div id="playerDetails-container">

                    <div id="top">

                        <div id="channelName">
                            <p>{{channelName}}</p>
                        </div>

                        <div id="channelSocials">
                            <a> <img src="../image/small-icon/facebook-icon.png"> </a>
                            <a> <img src="../image/small-icon/youtube-icon.png"> </a>
                            <a> <img src="../image/small-icon/twitch-icon.png"> </a>
                        </div>

                    </div>


                    <div id="mid">

                        <div class="mid-rows" > 
                            <div class="stat-name" id="first-stat-name"> BUILD </div>
                            <div class="stats-bar"> 
                                <div class="progress-bar" id="percentBar-1"> 100% </div>
                            </div>
                        </div>
                        
                        <div class="mid-rows">
                            <div class="stat-name" id="second-stat-name"> REDSTONE </div>
                            <div class="stats-bar"> 
                                <div class="progress-bar" id="percentBar-2"> 100% </div>
                            </div>
                        </div>

                        <div class="mid-rows">
                            <div class="stat-name" id="third-stat-name"> ROLEPLAYING </div>
                            <div class="stats-bar"> 
                                <div class="progress-bar" id="percentBar-3"> 100% </div>
                            </div>
                        </div>

                    </div>


                    <div id="bottom">

                        <div id="description"> 
                            <p id="description-content"> 
                            </p> 
                        </div>

                        <div id="builds-img">
                            <p class='no-highlight' id="previous-img" style="position: relative; height: 100%; width: 50%; font-size: 8em; text-align: left; left: 5%; line-height: 1.4em; cursor: pointer; "> < </p>
                            <p class='no-highlight' id="next-img" style="position: relative; height: 100%; width: 50%; font-size: 8em; text-align: right; right: 2%; line-height: 1.4em; cursor: pointer;" > > </p>
                        </div>

                    </div>
                    
                </div>

            </div>

            

            
    </div>

        


    </body>
</html>
